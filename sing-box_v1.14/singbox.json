{
    "http_clients": [
        {
            "tag": "proxy-client",
            "detour": "Default"
        }
    ],
    "services": [
        {
            "type": "api",
            "tag": "api",
            "listen": "0.0.0.0",
            "listen_port": 9090,
            "secret": "",
            "access_control_allow_origin": [ ],
            "access_control_allow_private_network": false,
            "dashboard": {
                "enabled": true,
                "path": "dashboard",
                "download_url": "https://github.com/Zephyruso/zashboard/releases/latest/download/dist.zip",
                "http_client": "proxy-client",
                "update_interval": "7d"
            },
            "tls": { }
        }
    ],
    "experimental": {
        "cache_file": {
            "enabled": true,
            "store_fakeip": true
        }
    },
    "log": {
        "level": "info",
        "timestamp": true
    },
    "dns": {
        "servers": [
            {
                "tag": "proxy_dns",
                "type": "https",
                "server": "1.1.1.1",
                "detour": "Default"
            },
            {
                "tag": "cn_dns",
                "type": "udp",
                "server": "114.114.114.114"
            },
            {
                "tag": "fake_dns",
                "type": "fakeip",
                "inet4_range": "11.0.0.0/16",
                "inet6_range": "3ffe::/16"
            }
        ],
        "rules": [
            {
                "type": "logical",
                "mode": "or",
                "rules": [
                    {
                        "domain_suffix": [ "ileidian.com", ".cn" ]
                    },
                    {
                        "domain_keyword": [ "stun", "turn" ]
                    },
                    {
                        "rule_set": "cnsite"
                    }
                ],
                "server": "cn_dns"
            },
            {
                "action": "evaluate",
                "server": "proxy_dns"
            },
            {
                "match_response": true,
                "rule_set": "cnip",
                "action": "route",
                "server": "cn_dns"
            },
            {
                "server": "fake_dns",
                "rewrite_ttl": 1
            }
        ]
    },
    "inbounds": [
        {
            "type": "tun",
            "tag": "tun-in",
            "interface_name": "singbox_tun",
            "address": [ "172.18.0.1/30", "fdfe:dcba:9876::1/126" ],
            "mtu": 9000,
            "auto_route": true,
            "route_exclude_address": [ "10.0.0.0/8", "100.64.0.0/10", "169.254.0.0/16", "172.16.0.0/12", "192.0.0.0/24", "192.168.0.0/16" ],
            "strict_route": true,
            "auto_redirect": true,
            "stack": "system"
        },
        {
            "type": "mixed",
            "tag": "mixed-in",
            "listen": "127.0.0.1",
            "listen_port": 7890
        }
    ],
    "outbounds": [
        {
            "type": "selector",
            "tag": "Default",
            "outbounds": [ "Auto", "Direct-Out" ]
        },
        {
            "type": "urltest",
            "tag": "Auto",
            "outbounds": [ ],
            "interval": "3m",
            "tolerance": 30
        },
        {
            "type": "selector",
            "tag": "Relay",
            "outbounds": [ "Direct-Out" ]
        },
        {
            "type": "selector",
            "tag": "PayPal",
            "outbounds": [ "Default", "Auto" ]
        },
        {
            "type": "selector",
            "tag": "AI-Service",
            "outbounds": [ "Default", "Auto" ]
        },
        {
            "type": "selector",
            "tag": "TikTok",
            "outbounds": [ "Default", "Auto" ]
        },
        {
            "type": "selector",
            "tag": "Streaming-Media",
            "outbounds": [ "Default", "Auto" ]
        },
        {
            "type": "selector",
            "tag": "Telegram",
            "outbounds": [ "Default", "Auto" ]
        },
        {
            "type": "selector",
            "tag": "Instagram",
            "outbounds": [ "Default", "Auto" ]
        },
        {
            "type": "selector",
            "tag": "Emby",
            "outbounds": [ "Default", "Auto", "Direct-Out" ]
        },
        {
            "type": "direct",
            "tag": "Direct-Out"
        }
    ],
    "route": {
        "final": "Default",
        "auto_detect_interface": true,
        "default_http_client": "proxy-client",
        "default_domain_resolver": { "server": "cn_dns" },
        "rule_set": [
            {
                "tag": "cnsite",
                "type": "remote",
                "format": "binary",
                "url": "https://github.com/MetaCubeX/meta-rules-dat/raw/refs/heads/sing/geo/geosite/cn.srs",
                "update_interval": "24h"
            },
            {
                "tag": "cnip",
                "type": "remote",
                "format": "binary",
                "url": "https://github.com/MetaCubeX/meta-rules-dat/raw/refs/heads/sing/geo/geoip/cn.srs",
                "update_interval": "24h"
            },
            {
                "tag": "cngames",
                "type": "remote",
                "format": "binary",
                "url": "https://github.com/MetaCubeX/meta-rules-dat/raw/refs/heads/sing/geo/geosite/category-games-!cn@cn.srs",
                "update_interval": "24h"
            },
            {
                "tag": "gfw",
                "type": "remote",
                "format": "binary",
                "url": "https://github.com/MetaCubeX/meta-rules-dat/raw/refs/heads/sing/geo/geosite/gfw.srs",
                "update_interval": "24h"
            },
            {
                "tag": "aiservice",
                "type": "remote",
                "format": "binary",
                "url": "https://github.com/MetaCubeX/meta-rules-dat/raw/refs/heads/sing/geo/geosite/category-ai-!cn.srs",
                "update_interval": "24h"
            },
            {
                "tag": "paypal",
                "type": "remote",
                "format": "binary",
                "url": "https://github.com/MetaCubeX/meta-rules-dat/raw/refs/heads/sing/geo/geosite/paypal.srs",
                "update_interval": "24h"
            },
            {
                "tag": "tiktok",
                "type": "remote",
                "format": "binary",
                "url": "https://github.com/MetaCubeX/meta-rules-dat/raw/refs/heads/sing/geo/geosite/tiktok.srs",
                "update_interval": "24h"
            },
            {
                "tag": "instagram",
                "type": "remote",
                "format": "binary",
                "url": "https://github.com/MetaCubeX/meta-rules-dat/raw/refs/heads/sing/geo/geosite/instagram.srs",
                "update_interval": "24h"
            },
            {
                "tag": "telegramip",
                "type": "remote",
                "format": "binary",
                "url": "https://github.com/MetaCubeX/meta-rules-dat/raw/refs/heads/sing/geo/geoip/telegram.srs",
                "update_interval": "24h"
            },
            {
                "tag": "telegramsite",
                "type": "remote",
                "format": "binary",
                "url": "https://github.com/MetaCubeX/meta-rules-dat/raw/refs/heads/sing/geo/geosite/telegram.srs",
                "update_interval": "24h"
            },
            {
                "tag": "netflixsite",
                "type": "remote",
                "format": "binary",
                "url": "https://github.com/MetaCubeX/meta-rules-dat/raw/refs/heads/sing/geo/geosite/netflix.srs",
                "update_interval": "24h"
            },
            {
                "tag": "netflixip",
                "type": "remote",
                "format": "binary",
                "url": "https://github.com/MetaCubeX/meta-rules-dat/raw/refs/heads/sing/geo/geoip/netflix.srs",
                "update_interval": "24h"
            },
            {
                "tag": "disney",
                "type": "remote",
                "format": "binary",
                "url": "https://github.com/MetaCubeX/meta-rules-dat/raw/refs/heads/sing/geo/geosite/disney.srs",
                "update_interval": "24h"
            },
            {
                "tag": "hbo",
                "type": "remote",
                "format": "binary",
                "url": "https://github.com/MetaCubeX/meta-rules-dat/raw/refs/heads/sing/geo/geosite/hbo.srs",
                "update_interval": "24h"
            },
            {
                "tag": "hulu",
                "type": "remote",
                "format": "binary",
                "url": "https://github.com/MetaCubeX/meta-rules-dat/raw/refs/heads/sing/geo/geosite/hulu.srs",
                "update_interval": "24h"
            },
            {
                "tag": "emby",
                "type": "remote",
                "format": "binary",
                "url": "https://github.com/MetaCubeX/meta-rules-dat/raw/refs/heads/sing/geo/geosite/category-emby.srs",
                "update_interval": "24h"
            }
        ],
        "rules": [
            {
                "type": "logical",
                "mode": "and",
                "rules": [
                    {
                        "port": 443
                    },
                    {
                        "network": "udp"
                    }
                ],
                "action": "reject"
            },
            {
                "network": "icmp",
                "outbound": "Direct-Out"
            },
            {
                "action": "sniff"
            },
            {
                "type": "logical",
                "mode": "or",
                "rules": [
                    {
                        "protocol": "dns"
                    },
                    {
                        "port": 53
                    }
                ],
                "action": "hijack-dns"
            },
            {
                "ip_is_private": true,
                "outbound": "Direct-Out"
            },
            {
                "protocol": "quic",
                "action": "reject"
            },
            {
                "protocol": "bittorrent",
                "outbound": "Direct-Out"
            },
            {
                "port": [ 3478, 5201 ],
                "outbound": "Direct-Out"
            },
            {
                "domain_suffix": [ "ileidian.com", "ottiptv.cc" ],
                "outbound": "Direct-Out"
            },
            {
                "domain_suffix": [ "uhdnow.com" ],
                "outbound": "Emby"
            },
            {
                "rule_set": "emby",
                "outbound": "Emby"
            },
            {
                "rule_set": "paypal",
                "outbound": "PayPal"
            },
            {
                "rule_set": "telegramsite",
                "outbound": "Telegram"
            },
            {
                "rule_set": "tiktok",
                "outbound": "TikTok"
            },
            {
                "rule_set": "instagram",
                "outbound": "Instagram"
            },
            {
                "rule_set": "aiservice",
                "outbound": "AI-Service"
            },
            {
                "domain_suffix": "sexlikereal.com",
                "outbound": "Streaming-Media"
            },
            {
                "rule_set": [ "netflixsite", "hbo", "disney", "hulu" ],
                "outbound": "Streaming-Media"
            },
            {
                "rule_set": "cngames",
                "outbound": "Direct-Out"
            },
            {
                "rule_set": "gfw",
                "outbound": "Default"
            },
            {
                "action": "resolve"
            },
            {
                "rule_set": "telegramip",
                "outbound": "Telegram"
            },
            {
                "rule_set": "netflixip",
                "outbound": "Streaming-Media"
            },
            {
                "rule_set": "cnip",
                "outbound": "Direct-Out"
            }
        ]
    }
}