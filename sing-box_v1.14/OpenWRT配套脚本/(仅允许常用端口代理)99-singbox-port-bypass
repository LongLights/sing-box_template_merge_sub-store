#!/bin/sh
# 放置于 /etc/hotplug.d/net/，例如：
# /etc/hotplug.d/net/99-singbox-port-bypass

[ "$ACTION" = "add" ] || exit 0
[ "$INTERFACE" = "singbox_tun" ] || exit 0

TABLE_FAMILY="inet"
TABLE_NAME="sing-box"
SET_NAME="common_ports_set"
BYPASS_CHAIN="port_bypass_chain"

COMMON_PORTS="53, 80, 123, 143, 194, 443, 465, 587, 853, 993, 995, 998, 2052, 2053, 2082, 2083, 2086, 2095, 2096, 5222, 5228, 5229, 5230, 8080, 8443, 8880, 8888, 8889"

# 等待 sing-box 完整创建 nftables 表和关键链。
RETRY_COUNT=15
while [ "$RETRY_COUNT" -gt 0 ]; do
    if nft list chain "$TABLE_FAMILY" "$TABLE_NAME" prerouting_prematch \
        >/dev/null 2>&1 &&
       nft list chain "$TABLE_FAMILY" "$TABLE_NAME" output_prematch \
        >/dev/null 2>&1; then
        break
    fi

    sleep 1
    RETRY_COUNT=$((RETRY_COUNT - 1))
done

[ "$RETRY_COUNT" -gt 0 ] || exit 1

# 幂等创建端口集合。
if ! nft list set "$TABLE_FAMILY" "$TABLE_NAME" "$SET_NAME" \
    >/dev/null 2>&1; then
    nft add set "$TABLE_FAMILY" "$TABLE_NAME" "$SET_NAME" \
        '{ type inet_service; flags interval; }' || exit 1
fi

nft flush set "$TABLE_FAMILY" "$TABLE_NAME" "$SET_NAME" || exit 1
nft add element "$TABLE_FAMILY" "$TABLE_NAME" "$SET_NAME" \
    "{ $COMMON_PORTS }" || exit 1

# 幂等创建旁路链。
if ! nft list chain "$TABLE_FAMILY" "$TABLE_NAME" "$BYPASS_CHAIN" \
    >/dev/null 2>&1; then
    nft add chain "$TABLE_FAMILY" "$TABLE_NAME" "$BYPASS_CHAIN" || exit 1
fi

nft flush chain "$TABLE_FAMILY" "$TABLE_NAME" "$BYPASS_CHAIN" || exit 1

# 非白名单目标端口不进入 sing-box。
# counter 用来确认 P2P 流量是否确实命中了旁路规则。
nft add rule "$TABLE_FAMILY" "$TABLE_NAME" "$BYPASS_CHAIN" \
    meta l4proto udp udp dport != @"$SET_NAME" \
    counter accept comment \"sing-box-port-bypass-udp\" || exit 1

nft add rule "$TABLE_FAMILY" "$TABLE_NAME" "$BYPASS_CHAIN" \
    meta l4proto tcp tcp dport != @"$SET_NAME" \
    counter accept comment \"sing-box-port-bypass-tcp\" || exit 1

nft add rule "$TABLE_FAMILY" "$TABLE_NAME" "$BYPASS_CHAIN" \
    return || exit 1

# 每一个相关 base chain 都必须旁路。
# prematch 链用于避开 NFQUEUE；其余链用于避开后续 mark/redirect。
for CHAIN in \
    prerouting_prematch \
    output_prematch \
    prerouting \
    prerouting_udp_icmp \
    output \
    output_udp_icmp
do
    if nft list chain "$TABLE_FAMILY" "$TABLE_NAME" "$CHAIN" \
        >/dev/null 2>&1; then
        if ! nft list chain "$TABLE_FAMILY" "$TABLE_NAME" "$CHAIN" |
            grep -q "jump $BYPASS_CHAIN"; then
            nft insert rule "$TABLE_FAMILY" "$TABLE_NAME" "$CHAIN" \
                jump "$BYPASS_CHAIN" \
                comment \"sing-box-port-bypass-hook\"
        fi
    fi
done

exit 0